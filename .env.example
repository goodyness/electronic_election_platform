# ─────────────────────────────────────────────────────────
# FlashVote .env.example — Copy this to .env and fill in values
# ─────────────────────────────────────────────────────────

# Core Django
DJANGO_SECRET_KEY=generate-a-new-key-with-python-secrets
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Database (PostgreSQL for production)
DB_NAME=election_db
DB_USER=postgres
DB_PASSWORD=your-strong-database-password
DB_HOST=localhost
DB_PORT=5432

# Email (Gmail SMTP)
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=your-app-password-from-google

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0

# Paystack (use LIVE keys in production)
PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxx
PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxx
